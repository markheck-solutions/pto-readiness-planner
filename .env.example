# Public demo posture (safe defaults)
NEXT_PUBLIC_DEMO_MODE=true
AI_PROVIDER=mock

# Supabase hosted Postgres connection string.
# Leave blank for public demo and early scaffold work.
DATABASE_URL=

# Optional private local OpenAI-compatible provider (server-only).
# These are ignored in public demo mode.
OPENAI_COMPATIBLE_BASE_URL=http://127.0.0.1:4010/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
